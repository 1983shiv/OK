# ─── apps/api — Backend Environment Variables ────────────────────────────────
# Copy this file to apps/api/.env for local development
# NEVER commit .env files with real values

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Use the pooled connection string for the app, direct URL for migrations
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── MongoDB (Atlas) ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/optionkart?retryWrites=true&w=majority

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6380

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@optionkart.com

# ── Upstox API ────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=         # Manually set after OAuth flow; refreshed daily by cron

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Plan IDs (create in Razorpay dashboard)
RAZORPAY_PLAN_STARTER_MONTHLY=plan_
RAZORPAY_PLAN_STARTER_YEARLY=plan_
RAZORPAY_PLAN_PRO_MONTHLY=plan_
RAZORPAY_PLAN_PRO_YEARLY=plan_
RAZORPAY_PLAN_ELITE_MONTHLY=plan_
RAZORPAY_PLAN_ELITE_YEARLY=plan_

# ── Encryption (AES-256-GCM for BYO OpenAI keys) ─────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Browser Push (VAPID) ──────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@optionkart.com

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend URL (for CORS + OAuth redirects) ────────────────────────────────
FRONTEND_URL=http://localhost:3000


# ─── apps/web — Frontend Environment Variables ───────────────────────────────
# Copy relevant vars to apps/web/.env.local for local development

# NEXT_PUBLIC_API_URL=http://localhost:3001/v1
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_POSTHOG_KEY=phc_
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
